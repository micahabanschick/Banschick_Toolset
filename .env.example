# ============================================================================
# BANSCHICK TOOLSET — Root Environment Variables
# ============================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env:   cp .env.example .env
#   2. Replace every placeholder below with real values
#   3. NEVER commit .env to Git
#
# NOTE: Each app also has its own .env file in apps/[appname]/.env
# for app-specific secrets (API keys, broker creds, Supabase keys).
# Those are NOT managed here — see the per-app .env.example files.
#
# See: Master Build Plan, Section 7.3
# ============================================================================

# ── PostgreSQL Admin (shared instance for future apps) ─────────────────────
# Neither QuantPipe nor StudyBuddy use this currently.
# QuantPipe uses Parquet/DuckDB; StudyBuddy uses Supabase.
# This is provisioned for future apps that need a local database.
POSTGRES_ADMIN_USER=banschick_admin
POSTGRES_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
