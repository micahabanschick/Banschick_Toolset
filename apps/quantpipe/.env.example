# ============================================================================
# QUANTPIPE — Environment Variables
# ============================================================================
# Copy to .env in this directory:  cp .env.example .env
# These are read by QuantPipe's config/settings.py
# See the QuantPipe repo's own .env.example for the full variable list.
# ============================================================================

# ── Data paths (set by Docker, but can be overridden) ──────────────────────
# QP_DATA_DIR=/app/data
# QP_LOG_DIR=/app/logs

# ── Broker credentials (Phase 6+) ─────────────────────────────────────────
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1

# ── Notifications ─────────────────────────────────────────────────────────
# PUSHOVER_USER_KEY=your_pushover_user_key
# PUSHOVER_API_TOKEN=your_pushover_api_token

# ── Crypto exchange (CCXT) ────────────────────────────────────────────────
# CCXT_EXCHANGE=kraken
# CCXT_API_KEY=your_exchange_api_key
# CCXT_SECRET=your_exchange_secret
