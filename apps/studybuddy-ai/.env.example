# ============================================================================
# STUDYBUDDY-AI — Environment Variables
# ============================================================================
# Copy to .env in this directory:  cp .env.example .env
# These are read by the FastAPI service (app/main.py)
# ============================================================================

# ── Supabase (for pgvector embeddings and document storage) ────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Anthropic (for RAG chat and quiz generation) ───────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
