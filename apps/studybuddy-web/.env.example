# ============================================================================
# STUDYBUDDY-WEB — Environment Variables
# ============================================================================
# Copy to .env in this directory:  cp .env.example .env
# These map to what Next.js reads from process.env / .env.local
# ============================================================================

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Anthropic (for server actions that call Claude directly) ───────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── AI Service (set by Docker Compose, override only if needed) ────────────
# AI_SERVICE_URL=http://studybuddy-ai:3003

# ── Prisma ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
